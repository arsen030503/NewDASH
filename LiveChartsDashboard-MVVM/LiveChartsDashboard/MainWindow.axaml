<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LiveChartsDashboard.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="LiveChartsDashboard.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Weather Dashboard">

    <StackPanel Margin="10">

        <TextBlock Text="Weather Dashboard" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Width="200" Watermark="Enter city name..." Text="{Binding CityInput}" />
            <Button Content="Get Weather"
                    Margin="10,0,0,0"
                    Command="{Binding GetWeatherCommand}" />
        </StackPanel>

        <TextBlock Text="{Binding CityName}" FontSize="16" />
        <TextBlock Text="{Binding Temperature}" FontSize="16" />
        <TextBlock Text="{Binding Pressure}" FontSize="16" />
        <TextBlock Text="{Binding Humidity}" FontSize="16" />

        <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="Red" Margin="0,10,0,0" />

    </StackPanel>
</Window>
